  "issues": {
    "controller_unavailable": {
      "title": "Pool Controller Unavailable",
      "description": "The pool controller **{name}** has been unreachable for {failures} consecutive polling cycles.\n\nPlease check:\n- Is the controller powered on?\n- Is the network connection OK?\n- Is the IP address still correct?\n\nOnce the controller is reachable again, this issue will be resolved automatically."
    }
  },
  "services": {
    "turn_auto": {
      "name": "Activate AUTO Mode",
      "description": "Switches devices to intelligent automatic mode.\n\nThe system now takes over optimal control based on sensor data and schedules.",
      "fields": {
        "entity_id": {
          "name": "Devices to Control",
          "description": "Select the devices to switch to AUTO mode."
        },
        "auto_delay": {
          "name": "Delay (seconds)",
          "description": "Wait time before AUTO mode is activated (0-86400s)."
        }
      }
    },
    "set_pv_surplus": {
      "name": "Use PV Surplus",
      "description": "Activates photovoltaic surplus mode for optimal solar power usage.\n\nPool devices are automatically operated with excess solar power.",
      "fields": {
        "entity_id": {
          "name": "PV Surplus Switch",
          "description": "The controller's PV surplus switch."
        },
        "pump_speed": {
          "name": "Pump Speed",
          "description": "Desired pump power (1=Eco, 2=Normal, 3=Maximum)."
        }
      }
    },
    "manual_dosing": {
      "name": "Manual Dosing",
      "description": "Starts manual dosing for the desired duration.\n\nCaution: Avoid overdosing! Always check water values first.",
      "fields": {
        "entity_id": {
          "name": "Dosing System",
          "description": "Select the dosing system (pH+, pH-, Chlorine, etc.)."
        },
        "duration_seconds": {
          "name": "Dosing Duration (seconds)",
          "description": "How long should dosing run? (1-3600s, start with short times!)"
        }
      }
    },
    "test_output": {
      "name": "Output Test Mode",
      "description": "Temporarily activates a controller output for diagnostics. Make sure no people or equipment are at risk while the output is forced.",
      "fields": {
        "output": {
          "name": "Output Identifier",
          "description": "Identifier such as PUMP, HEATER or SOLAR"
        },
        "mode": {
          "name": "Test Mode",
          "description": "SWITCH=toggle, ON=force on, OFF=force off"
        },
        "duration": {
          "name": "Test Duration (seconds)",
          "description": "Duration between 1 and 900 seconds"
        }
      }
    },
    "set_temperature_target": {
      "name": "Set Target Temperature",
      "description": "Sets the desired pool temperature.\n\nThe controller automatically heats to this temperature and maintains it.",
      "fields": {
        "entity_ids": {
          "name": "Heating Systems",
          "description": "Select heater and/or solar absorber."
        },
        "temperature": {
          "name": "Target Temperature (°C)",
          "description": "Desired pool temperature (20-35°C recommended)."
        }
      }
    },
    "set_ph_target": {
      "name": "Set pH Target",
      "description": "Defines the ideal pH value for automatic dosing.\n\nRecommended range: 7.0-7.4 for optimal water quality and skin compatibility.",
      "fields": {
        "entity_ids": {
          "name": "pH Dosing System",
          "description": "Select the controller's pH control."
        },
        "target_value": {
          "name": "pH Target",
          "description": "Desired pH value (6.8-7.8, optimal: 7.0-7.4)."
        }
      }
    },
    "set_chlorine_target": {
      "name": "Set Chlorine Target",
      "description": "Determines the target chlorine content for safe disinfection.\n\nSufficient chlorine eliminates bacteria, too much irritates skin and eyes.",
      "fields": {
        "entity_ids": {
          "name": "Chlorine Dosing System",
          "description": "Chlorine dosing or electrolysis system."
        },
        "target_value": {
          "name": "Chlorine Target (mg/l)",
          "description": "Desired free chlorine content (0.3-1.5 mg/l recommended)."
        }
      }
    },
    "trigger_backwash": {
      "name": "Start Backwash",
      "description": "Starts a filter backwash for cleaning.\n\nRemoves dirt and deposits for optimal filter performance.",
      "fields": {
        "entity_ids": {
          "name": "Backwash System",
          "description": "Backwash valve or filter automation."
        },
        "duration": {
          "name": "Backwash Duration (seconds)",
          "description": "Rinse duration (60-300s typical, 0=manual end)."
        }
      }
    },
    "start_water_analysis": {
      "name": "Start Water Analysis",
      "description": "Starts an automatic water analysis of all parameters.\n\nMeasures pH, chlorine, temperature and other values for optimization suggestions.",
      "fields": {
        "entity_ids": {
          "name": "Controller",
          "description": "Violet Pool Controller for analysis."
        }
      }
    },
    "set_maintenance_mode": {
      "name": "Maintenance Mode",
      "description": "Enables/disables maintenance mode.\n\nIn maintenance mode, all automation is paused for safe pool work.",
      "fields": {
        "entity_ids": {
          "name": "Controller",
          "description": "Select Violet Pool Controller."
        },
        "enable": {
          "name": "Enable Maintenance Mode",
          "description": "On: Stop all automation | Off: Resume normal operation."
        }
      }
    },
    "set_all_dmx_scenes_mode": {
      "name": "Control DMX Lighting",
      "description": "Controls all DMX light scenes simultaneously.\n\nPerfect for uniform light effects or complete on/off switching.",
      "fields": {
        "device_id": {
          "name": "Pool Controller",
          "description": "Violet Pool Controller with DMX output."
        },
        "dmx_mode": {
          "name": "Light Mode",
          "description": "All lights: On/Off/Automatic."
        }
      }
    },
    "set_digital_input_rule_lock_state": {
      "name": "Lock Switching Rule",
      "description": "Locks or unlocks digital switching rules.\n\nPrevents unwanted triggering during maintenance or faults.",
      "fields": {
        "device_id": {
          "name": "Pool Controller",
          "description": "Violet Pool Controller with digital rules."
        },
        "rule_key": {
          "name": "Rule Number",
          "description": "Number of the rule to lock (DIRULE_1 through DIRULE_7)."
        },
        "lock_state": {
          "name": "Lock",
          "description": "Lock rule (On) or release (Off)."
        }
      }
    },
    "trigger_digital_input_rule": {
      "name": "Trigger Switching Rule",
      "description": "Manually triggers a digital switching rule.\n\nUseful for testing automation or manual control when needed.",
      "fields": {
        "device_id": {
          "name": "Pool Controller",
          "description": "Violet Pool Controller with the rules."
        },
        "rule_key": {
          "name": "Rule Number",
          "description": "Which rule to trigger? (DIRULE_1 through DIRULE_7)"
        }
      }
    },
    "export_diagnostic_logs": {
      "name": "Export Diagnostic Logs",
      "description": "Exports recent integration logs for troubleshooting and support.",
      "fields": {
        "device_id": {
          "name": "Pool Controller",
          "description": "Violet Pool Controller for the export"
        },
        "lines": {
          "name": "Number of Lines",
          "description": "How many recent log lines to export? (10-1000)"
        },
        "include_timestamps": {
          "name": "Include Timestamps",
          "description": "Include timestamps in the exported logs"
        },
        "save_to_file": {
          "name": "Save to File",
          "description": "Save logs as a text file in the /config/ directory"
        }
      }
    }
  },
